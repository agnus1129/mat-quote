# 공공데이터포털 단지 API 키 (필수)
SERVICE_KEY=여기에_발급받은_서비스키
PORT=4000

# 관리자 대시보드 비밀번호 (필수 — 운영 시 강한 값으로)
ADMIN_PASS=강한비밀번호로_변경

# 배포 도메인 (소셜 로그인 사용 시 필수, https)
BASE_URL=https://your-domain.com

# 소셜 로그인 (선택)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 개인정보·로그 보관기간(일)
RETENTION_LEADS=365
RETENTION_LOGS=180

# 키 없이 흐름 확인:  MOCK=1

# 새 리드 알림·백업 (모두 선택)
# 텔레그램(무료): 봇 생성(@BotFather)→토큰, 본인 chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 범용 웹훅(슬랙/디스코드/카톡 솔루션 등)
NOTIFY_WEBHOOK=
# 구글시트 백업(무료 영속): Apps Script 웹앱 URL
SHEETS_WEBHOOK=

# CORS 허용 도메인(운영 시 자기 앱 주소만, 콤마구분). 비우면 전체 허용
ALLOW_ORIGIN=

# ===== 견적서 문자(SMS/LMS) 발송 (#3, 선택) =====
# 알리고(aligo) 문자 서비스: https://smartsms.aligo.in  (발신번호 사전등록 필요)
ALIGO_KEY=
ALIGO_USER=
ALIGO_SENDER=
# 또는 다른 문자 솔루션 웹훅(POST {phone,msg,title})
SMS_WEBHOOK=
# 실제 발송·과금 없이 자격증명만 점검하려면 Y (검증 끝나면 지우거나 N)
ALIGO_TESTMODE=
# 위 미설정 시: 발송요청은 '접수'로 저장되고 관리자에게 알림만 감(고객 놓치지 않게)

# ===== 고객 후기 (#1, 선택) =====
# 사전승인제로 운영하려면 0 (기본: 자동 노출)
REVIEW_AUTO_APPROVE=1

# ===== 주소 실검증(선택, 서버측) =====
# 도로명주소 API 승인키: https://business.juso.go.kr (없어도 앱은 카카오 우편번호로 실주소만 입력됨)
JUSO_KEY=
